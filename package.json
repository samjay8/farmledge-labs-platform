{
  "name": "farmledge-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/custodian",
    "apps/farmer",
    "apps/lender",
    "packages/shared"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "build:api": "npm run build --workspace=apps/api",
    "build:custodian": "npm run build --workspace=apps/custodian",
    "build:farmer": "npm run build --workspace=apps/farmer",
    "build:lender": "npm run build --workspace=apps/lender"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
